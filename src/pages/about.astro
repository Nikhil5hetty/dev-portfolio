---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PROFILE } from "@/data/profile";
import { SITE } from "@/site";
import { withBase } from "@/lib/withBase";
---

<BaseLayout title={`About Me | ${SITE.author}`} description="Background, skills, and resume download.">
  <section class="space-y-6">
    <p class="text-xs uppercase tracking-[0.28em] text-[var(--accent)]">About Me</p>
    <h1 class="text-5xl font-semibold tracking-[-0.04em] text-[var(--text)] sm:text-6xl">
      I build data systems and explain the trade-offs clearly.
    </h1>
    <p class="max-w-3xl text-lg leading-8 text-[var(--muted)] sm:text-[1.15rem]">
      This site is the public version of my data engineering story: the systems I build, the tools
      I use, and the work I care about most.
    </p>
  </section>

  <section class="mt-10 grid gap-5 lg:grid-cols-2">
    <div class="panel rounded-[2rem] p-6">
      <h2 class="text-xl font-semibold text-[var(--text)]">What I want to be known for</h2>
      <ul class="mt-4 space-y-3 text-sm leading-6 text-[var(--muted)]">
        {PROFILE.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="panel rounded-[2rem] p-6">
      <h2 class="text-xl font-semibold text-[var(--text)]">Experience snapshot</h2>
      <ul class="mt-4 space-y-3 text-sm leading-6 text-[var(--muted)]">
        <li>Databricks Lakehouse architecture and Spark optimization</li>
        <li>Structured Streaming, Kafka, and reliable ingestion</li>
        <li>Bronze / Silver / Gold ETL and cloud migration work</li>
        <li>Production monitoring, quality, and job stability</li>
      </ul>
    </div>
  </section>

  <section class="mt-10 grid gap-5">
    <div class="panel rounded-[2rem] p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Resume</p>
      <p class="mt-4 text-sm leading-6 text-[var(--muted)]">
        If you want the full work history, download the resume below. It includes the roles,
        projects, and impact metrics that support the summaries on this site.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={withBase(PROFILE.resumePath)}
          download
          class="inline-flex rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--accent-strong)]"
        >
          Download resume
        </a>
        <a
          href={withBase("/resume/")}
          class="inline-flex rounded-full border border-[var(--line)] px-5 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)]/40 hover:bg-[var(--surface-strong)]"
        >
          Open resume page
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
