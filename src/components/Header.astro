---
import { NAV_LINKS, SITE } from "@/site";
import { withBase } from "@/lib/withBase";
import ThemeToggle from "@/components/ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-[var(--line)] bg-[color:var(--nav-bg)]/80 backdrop-blur-xl">
  <div class="container grid gap-4 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
    <a href={withBase("/")} class="group flex items-center gap-3">
      <span class="text-lg font-semibold tracking-[0.04em] text-[var(--accent)] sm:text-xl">
        NIKHIL SHETTY
      </span>
    </a>

    <div class="flex flex-wrap items-center gap-3 sm:justify-end">
      <nav aria-label="Primary" class="w-full sm:w-auto">
        <ul class="flex flex-wrap items-center gap-2 text-[1rem] font-medium text-[var(--muted)] sm:justify-end sm:gap-3 sm:text-[1.05rem]">
          {
            NAV_LINKS.map((link) => {
              const href = withBase(link.href);
              const active =
                currentPath === href || currentPath === `${href.replace(/\/$/, "")}/`;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "rounded-full px-3.5 py-2.5 transition-colors hover:bg-[var(--surface)] hover:text-[var(--text)]",
                      active && "bg-[var(--surface)] text-[var(--text)]",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
