---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isPublished, sortByDateDesc } from "@/lib/content";
import { formatDate } from "@/lib/formatDate";
import { withBase } from "@/lib/withBase";
import { SITE } from "@/site";

const projects = sortByDateDesc((await getCollection("projects")).filter(isPublished));
---

<BaseLayout title={`Projects | ${SITE.author}`} description="Selected data engineering projects.">
  <article class="project-article project-index mx-auto w-full">
    <header class="blog-header space-y-6">
      <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
        <span class="blog-kicker">Projects</span>
        <span aria-hidden="true">•</span>
        <span>Engineering notes</span>
      </div>

      <h1 class="blog-title project-title">
        Long-form project writing
      </h1>

      <p class="blog-dek project-dek">
        These project entries are written like technical articles: the problem, the system shape, the
        implementation choices, and the tradeoffs are all visible in one reading flow.
      </p>
    </header>

    <section class="project-list" aria-label="Projects archive">
      {projects.map((project) => (
        <article class="project-list-item">
          <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
            <span class="blog-kicker text-[0.68rem]">{project.data.category}</span>
            <span aria-hidden="true">•</span>
            <time datetime={project.data.date.toISOString()}>{formatDate(project.data.date)}</time>
            <span aria-hidden="true">•</span>
            <span class="uppercase tracking-[0.14em]">{project.data.status}</span>
          </div>

          <h2 class="project-list-title">
            <a href={withBase(`/projects/${project.slug}/`)} class="transition hover:text-[var(--accent)]">
              {project.data.title}
            </a>
          </h2>

          <p class="project-list-dek">{project.data.description}</p>

          <div class="project-list-meta">
            {project.data.stack.slice(0, 5).map((item) => (
              <span class="project-list-tag">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </section>
  </article>
</BaseLayout>
