---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/formatDate";
import { isPublished } from "@/lib/content";
import { withBase } from "@/lib/withBase";
import { SITE } from "@/site";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter(isPublished);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const tags = project.data.tags ?? [];
---

<BaseLayout title={`${project.data.title} | ${SITE.author}`} description={project.data.description}>
  <article class="project-article mx-auto w-full">
    <header class="blog-header space-y-6">
      <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
        <span class="blog-kicker">Project</span>
        <span aria-hidden="true">•</span>
        <span>{project.data.category}</span>
        <span aria-hidden="true">•</span>
        <time datetime={project.data.date.toISOString()}>{formatDate(project.data.date)}</time>
        <span aria-hidden="true">•</span>
        <span class="uppercase tracking-[0.14em]">{project.data.status}</span>
      </div>

      <h1 class="blog-title project-title">
        {project.data.title}
      </h1>

      <p class="blog-dek project-dek">
        {project.data.description}
      </p>

      <div class="flex flex-wrap items-center gap-3 pt-1">
        {project.data.repo && (
          <a
            href={project.data.repo}
            target="_blank"
            rel="noreferrer"
            class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface)] px-4 py-2 text-sm font-medium text-[var(--text)] transition hover:border-[var(--accent)]/35 hover:bg-[var(--surface-strong)]"
          >
            View code
          </a>
        )}

        {project.data.link && (
          <a
            href={project.data.link}
            target="_blank"
            rel="noreferrer"
            class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface)] px-4 py-2 text-sm font-medium text-[var(--text)] transition hover:border-[var(--accent)]/35 hover:bg-[var(--surface-strong)]"
          >
            Open project
          </a>
        )}
      </div>

      {(tags.length > 0 || project.data.stack.length > 0) && (
        <div class="space-y-3 pt-2">
          {tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li class="rounded-full border border-[var(--line)] bg-[var(--surface)] px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-[var(--muted)]">
                  {tag}
                </li>
              ))}
            </ul>
          )}

          {project.data.stack.length > 0 && (
            <p class="project-stackline">
              <span>Stack</span>
              {project.data.stack.join(" · ")}
            </p>
          )}
        </div>
      )}
    </header>

    <section class="project-summary" aria-label="Project summary">
      <article class="project-summary-item">
        <p class="project-summary-label">Challenge</p>
        <p class="project-summary-value">{project.data.challenge}</p>
      </article>
      <article class="project-summary-item">
        <p class="project-summary-label">Architecture</p>
        <p class="project-summary-value">{project.data.architecture}</p>
      </article>
      <article class="project-summary-item">
        <p class="project-summary-label">Scale</p>
        <p class="project-summary-value">{project.data.scale}</p>
      </article>
      <article class="project-summary-item">
        <p class="project-summary-label">Outcome</p>
        <p class="project-summary-value">{project.data.outcome}</p>
      </article>
    </section>

    {project.data.diagram && (
      <figure class="project-hero-figure">
        <img
          src={withBase(project.data.diagram)}
          alt={`${project.data.title} architecture diagram`}
          loading="lazy"
          decoding="async"
        />
      </figure>
    )}

    <div class="project-body">
      <div class="prose-custom max-w-none">
        <Content />

        {project.data.lessons.length > 0 && (
          <section class="scroll-mt-28">
            <h2>Lessons learned</h2>
            <ul>
              {project.data.lessons.map((lesson) => (
                <li>{lesson}</li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
