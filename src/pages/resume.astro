---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PROFILE } from "@/data/profile";
import { SITE } from "@/site";
import { withBase } from "@/lib/withBase";
---

<BaseLayout title={`Resume | ${SITE.author}`} description={PROFILE.summary}>
  <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
    <div class="panel rounded-[2rem] p-8 sm:p-10">
      <p class="text-xs uppercase tracking-[0.32em] text-[var(--accent)]">Resume</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.05em] text-[var(--text)] sm:text-6xl">
        {PROFILE.name}
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--muted)] sm:text-[1.1rem]">
        {PROFILE.summary}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={withBase(PROFILE.resumePath)}
          class="rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--accent-strong)]"
        >
          Download PDF
        </a>
        <a
          href={`mailto:${PROFILE.email}`}
          class="rounded-full border border-[var(--line)] px-5 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)]/40 hover:bg-[var(--surface-strong)]"
        >
          Email me
        </a>
      </div>
    </div>

    <aside class="grid gap-4">
      <div class="panel rounded-[2rem] p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Impact</p>
        <div class="mt-4 grid gap-3">
          {PROFILE.impactCards.map((metric) => (
            <div class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--surface-strong)] p-4">
              <p class="text-3xl font-semibold tracking-[-0.04em] text-[var(--text)]">{metric.value}</p>
              <p class="mt-1 text-sm text-[var(--muted)]">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="panel rounded-[2rem] p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Core stack</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {PROFILE.coreStack.map((skill) => (
            <span class="rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-3 py-1 text-xs text-[var(--muted)]">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </aside>
  </section>

  <section class="mt-16 space-y-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.32em] text-[var(--accent)]">Experience</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-[-0.03em] text-[var(--text)] sm:text-[2.75rem]">
          Production data engineering
        </h2>
      </div>
    </div>

    <div class="grid gap-5">
      {PROFILE.experience.map((item) => (
        <article class="panel rounded-[2rem] p-6 sm:p-7">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div>
              <h3 class="text-2xl font-semibold text-[var(--text)]">{item.company}</h3>
              <p class="mt-1 text-sm text-[var(--muted)]">
                {item.role} · {item.period}
              </p>
            </div>
          </div>
          <ul class="mt-5 grid gap-3 text-[var(--muted)]">
            {item.bullets.map((bullet) => (
              <li class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--surface-strong)] p-4">
                {bullet}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-16 grid gap-5 lg:grid-cols-[0.65fr_1.35fr]">
    <div class="panel rounded-[2rem] p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Education</p>
      <div class="mt-4 space-y-4">
        {PROFILE.education.map((item) => (
          <div class="rounded-[1.5rem] border border-[var(--line)] bg-[var(--surface-strong)] p-5">
            <h3 class="text-lg font-semibold text-[var(--text)]">{item.school}</h3>
            <p class="mt-1 text-sm text-[var(--muted)]">{item.credential}</p>
            <p class="mt-2 text-xs uppercase tracking-[0.24em] text-[var(--muted)]">{item.period}</p>
            <p class="mt-3 text-sm text-[var(--muted)]">{item.note}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="panel rounded-[2rem] p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Certifications</p>
      <ul class="mt-4 grid gap-3 text-[var(--muted)]">
        {PROFILE.certifications.map((cert) => (
          <li class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--surface-strong)] p-4">
            {cert}
          </li>
        ))}
      </ul>
      <p class="mt-6 text-sm leading-6 text-[var(--muted)]">
        These targets are listed because they reinforce the themes recruiters already care about in
        my background: Databricks, cloud data architecture, and production-grade delivery.
      </p>
    </div>
  </section>
</BaseLayout>

