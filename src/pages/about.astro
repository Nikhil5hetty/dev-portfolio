---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PROFILE } from "@/data/profile";
import { SITE } from "@/site";
import { withBase } from "@/lib/withBase";
---

<BaseLayout title={`About Me | ${SITE.author}`} description="Background, experience, and resume download.">
  <section class="panel rounded-[2rem] p-8 sm:p-10">
    <div class="space-y-6">
      <p class="text-xs uppercase tracking-[0.28em] text-[var(--accent)]">About Me</p>
      <div class="about-hero-copy space-y-5">
      <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.04em] text-[var(--text)] sm:text-6xl">
        Data Engineer and curious problem solver with 8+ years of professional experience.
      </h1>
        <p class="max-w-3xl text-lg leading-8 text-[var(--muted)] sm:text-[1.15rem]">
          {PROFILE.summary}
        </p>
        <p class="max-w-3xl text-base leading-7 text-[var(--muted)]">
          I am currently in the final semester of my MSc in Computer Science in Bern, working on my
          thesis and open to opportunities in Switzerland that align with my Spark, Databricks, and
          production data engineering skill set.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <span class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-4 py-2 text-sm text-[var(--accent)]">
          {PROFILE.role}
        </span>
        <span class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-4 py-2 text-sm text-[var(--accent)]">
          {PROFILE.currentStudy}
        </span>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <a
          href={withBase(PROFILE.resumePath)}
          download
          class="inline-flex rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--accent-strong)]"
        >
          Download resume
        </a>
        <a
          href={withBase("/resume/")}
          class="inline-flex rounded-full border border-[var(--line)] px-5 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)]/40 hover:bg-[var(--surface-strong)]"
        >
          Open resume page
        </a>
      </div>
    </div>
  </section>

  <section class="mt-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.32em] text-[var(--accent)]">Experience</p>
        <h2 class="experience-section-title mt-2 text-4xl font-semibold tracking-[-0.03em] text-[var(--text)] sm:text-[2.75rem]">
          Professional experience
        </h2>
      </div>
    </div>

    <div class="mt-6 grid gap-5">
      {PROFILE.experience.map((item) => (
        <article class="panel rounded-[2rem] border-l-4 border-l-[var(--accent)] p-6 sm:p-7 experience-card">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="space-y-1">
              <p class="experience-kicker text-xs uppercase tracking-[0.24em] text-[var(--accent)]">
                {item.domain}
              </p>
              <h3 class="experience-company font-semibold tracking-[-0.03em] text-[var(--text)]">
                {item.company}
              </h3>
              <p class="experience-meta text-sm text-[var(--muted)]">
                {item.role} · {item.period}
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-3 py-1 text-xs text-[var(--accent)]">
                {item.domain}
              </span>
              {item.workMode && (
                <span class="inline-flex rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-3 py-1 text-xs text-[var(--accent)]">
                  {item.workMode}
                </span>
              )}
            </div>
          </div>

          <div class="mt-5 grid gap-4">
            <p class="experience-copy text-[var(--muted)]">
              {item.summary}
            </p>
            <div class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--surface-strong)] p-5">
              <p class="text-xs uppercase tracking-[0.24em] text-[var(--accent)]">Selected contributions</p>
              <p class="experience-copy mt-2 text-[var(--muted)]">
                {item.highlights.join(" • ")}
              </p>
            </div>
            <div class="rounded-[1.25rem] border border-[var(--line)] bg-[var(--surface-strong)] p-5">
              <p class="text-xs uppercase tracking-[0.24em] text-[var(--accent)]">Business impact</p>
              <p class="mt-2 text-[var(--muted)] text-[1.08rem] leading-8">{item.impact}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-16 grid gap-5 lg:grid-cols-[1fr_1fr]">
    <div class="panel rounded-[2rem] p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Core stack</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-[var(--text)]">
        Tools I use most often
      </h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {PROFILE.coreStack.map((skill) => (
          <span class="rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-3 py-1 text-xs text-[var(--muted)]">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <div class="panel rounded-[2rem] p-6">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--accent)]">Resume</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-[var(--text)]">
        Download the full work history
      </h2>
      <p class="mt-4 text-sm leading-6 text-[var(--muted)]">
        The resume includes role history, project highlights, and the delivery metrics behind the
        work summarized on this site.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={withBase(PROFILE.resumePath)}
          download
          class="inline-flex rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--accent-strong)]"
        >
          Download resume
        </a>
        <a
          href={withBase("/resume/")}
          class="inline-flex rounded-full border border-[var(--line)] px-5 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)]/40 hover:bg-[var(--surface-strong)]"
        >
          Open resume page
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
