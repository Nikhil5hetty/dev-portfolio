---
import { SOCIAL_LINKS, SITE } from "@/site";
---

<footer class="border-t border-[var(--line)] py-10">
  <div class="container flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
    <p class="max-w-xl text-sm leading-6 text-[var(--muted)]">
      © {new Date().getFullYear()} {SITE.author}. Built with Astro, published as a GitHub Pages project site,
      tuned for content first, and created with AI-assisted support.
    </p>

    <div class="flex flex-wrap gap-4 text-sm text-[var(--text)]">
      {
        SOCIAL_LINKS.map((social) => (
          <a class="transition-colors hover:text-[var(--accent)]" href={social.href}>
            {social.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
